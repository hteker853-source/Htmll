<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>💰 Income & Expense Tracker</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            min-height: 100vh;
            padding: 20px;
        }

        .container {
            max-width: 1200px;
            margin: 0 auto;
        }

        h1 {
            text-align: center;
            color: white;
            font-size: 2.5rem;
            margin-bottom: 30px;
            text-shadow: 2px 2px 4px rgba(0,0,0,0.3);
        }

        .dashboard {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
            gap: 20px;
            margin-bottom: 30px;
        }

        .card {
            background: white;
            border-radius: 20px;
            padding: 25px;
            box-shadow: 0 10px 30px rgba(0,0,0,0.2);
            transition: transform 0.3s ease;
        }

        .card:hover {
            transform: translateY(-5px);
        }

        .card.income { border-top: 5px solid #10b981; }
        .card.expense { border-top: 5px solid #ef4444; }
        .card.balance { border-top: 5px solid #3b82f6; }
        .card.savings { border-top: 5px solid #f59e0b; }

        .card-icon {
            font-size: 2.5rem;
            margin-bottom: 10px;
        }

        .card-title {
            color: #6b7280;
            font-size: 0.9rem;
            text-transform: uppercase;
            letter-spacing: 1px;
            margin-bottom: 5px;
        }

        .card-value {
            font-size: 2rem;
            font-weight: bold;
            color: #1f2937;
        }

        .income .card-value { color: #10b981; }
        .expense .card-value { color: #ef4444; }
        .balance .card-value { color: #3b82f6; }
        .savings .card-value { color: #f59e0b; }

        .tables-section {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(500px, 1fr));
            gap: 30px;
            margin-bottom: 30px;
        }

        .table-container {
            background: white;
            border-radius: 20px;
            padding: 25px;
            box-shadow: 0 10px 30px rgba(0,0,0,0.2);
        }

        .table-header {
            display: flex;
            align-items: center;
            margin-bottom: 20px;
            padding-bottom: 15px;
            border-bottom: 3px solid #e5e7eb;
        }

        .table-header.income-header { border-color: #10b981; }
        .table-header.expense-header { border-color: #ef4444; }

        .table-header h2 {
            font-size: 1.5rem;
            color: #1f2937;
            margin-left: 10px;
        }

        table {
            width: 100%;
            border-collapse: collapse;
        }

        th {
            background: #f3f4f6;
            padding: 12px;
            text-align: left;
            font-weight: 600;
            color: #4b5563;
            font-size: 0.85rem;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }

        td {
            padding: 12px;
            border-bottom: 1px solid #e5e7eb;
        }

        tr:hover {
            background: #f9fafb;
        }

        input[type="text"],
        input[type="number"],
        input[type="date"],
        select {
            width: 100%;
            padding: 8px 12px;
            border: 2px solid #e5e7eb;
            border-radius: 8px;
            font-size: 0.95rem;
            transition: all 0.3s ease;
        }

        input:focus,
        select:focus {
            outline: none;
            border-color: #667eea;
            box-shadow: 0 0 0 3px rgba(102, 126, 234, 0.1);
        }

        .amount-input {
            text-align: right;
            font-weight: 600;
        }

        .income-row .amount-input { color: #10b981; }
        .expense-row .amount-input { color: #ef4444; }

        .btn {
            padding: 10px 20px;
            border: none;
            border-radius: 8px;
            cursor: pointer;
            font-size: 0.9rem;
            font-weight: 600;
            transition: all 0.3s ease;
            margin-right: 10px;
        }

        .btn-add {
            background: #10b981;
            color: white;
        }

        .btn-add:hover {
            background: #059669;
        }

        .btn-remove {
            background: #ef4444;
            color: white;
            padding: 6px 12px;
            font-size: 0.8rem;
        }

        .btn-remove:hover {
            background: #dc2626;
        }

        .btn-save {
            background: #3b82f6;
            color: white;
            padding: 15px 40px;
            font-size: 1.1rem;
        }

        .btn-save:hover {
            background: #2563eb;
        }

        .total-row {
            background: #f3f4f6 !important;
            font-weight: bold;
        }

        .total-row td {
            border-top: 2px solid #d1d5db;
            border-bottom: none;
        }

        .action-buttons {
            text-align: center;
            margin-top: 30px;
        }

        .progress-bar {
            width: 100%;
            height: 10px;
            background: #e5e7eb;
            border-radius: 5px;
            overflow: hidden;
            margin-top: 10px;
        }

        .progress-fill {
            height: 100%;
            background: linear-gradient(90deg, #10b981, #059669);
            transition: width 0.5s ease;
        }

        .status-message {
            text-align: center;
            padding: 15px;
            margin-top: 20px;
            border-radius: 10px;
            font-weight: 600;
            display: none;
        }

        .status-positive {
            background: #d1fae5;
            color: #065f46;
        }

        .status-negative {
            background: #fee2e2;
            color: #991b1b;
        }

        @media (max-width: 768px) {
            .tables-section {
                grid-template-columns: 1fr;
            }

            h1 {
                font-size: 1.8rem;
            }

            .card-value {
                font-size: 1.5rem;
            }
        }
    </style>
</head>
<body>
    <div class="container">
        <h1>💰 Income & Expense Tracker</h1>

        <!-- Summary Cards -->
        <div class="dashboard">
            <div class="card income">
                <div class="card-icon">📈</div>
                <div class="card-title">Total Income</div>
                <div class="card-value" id="totalIncome">$0.00</div>
            </div>
            <div class="card expense">
                <div class="card-icon">📉</div>
                <div class="card-title">Total Expenses</div>
                <div class="card-value" id="totalExpense">$0.00</div>
            </div>
            <div class="card balance">
                <div class="card-icon">💵</div>
                <div class="card-title">Net Balance</div>
                <div class="card-value" id="netBalance">$0.00</div>
            </div>
            <div class="card savings">
                <div class="card-icon">🎯</div>
                <div class="card-title">Savings Rate</div>
                <div class="card-value" id="savingsRate">0%</div>
                <div class="progress-bar">
                    <div class="progress-fill" id="progressBar" style="width: 0%"></div>
                </div>
            </div>
        </div>

        <!-- Tables -->
        <div class="tables-section">
            <!-- Income Table -->
            <div class="table-container">
                <div class="table-header income-header">
                    <span style="font-size: 1.8rem;">📥</span>
                    <h2>Income Tracking</h2>
                </div>
                <table id="incomeTable">
                    <thead>
                        <tr>
                            <th>Date</th>
                            <th>Income Source</th>
                            <th>Description</th>
                            <th>Amount ($)</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody id="incomeBody">
                        <tr class="income-row">
                            <td><input type="date" class="date-input"></td>
                            <td>
                                <select class="source-input">
                                    <option value="">Select</option>
                                    <option value="Etsy Sales">Etsy Sales</option>
                                    <option value="Gumroad Sales">Gumroad Sales</option>
                                    <option value="Fiverr">Fiverr</option>
                                    <option value="Shopify">Shopify</option>
                                    <option value="Freelance">Freelance</option>
                                    <option value="YouTube">YouTube</option>
                                    <option value="Other Digital">Other Digital</option>
                                    <option value="Salary">Salary</option>
                                    <option value="Investments">Investments</option>
                                </select>
                            </td>
                            <td><input type="text" class="desc-input" placeholder="Description..."></td>
                            <td><input type="number" class="amount-input" placeholder="0.00" step="0.01" min="0"></td>
                            <td><button class="btn btn-remove" onclick="removeRow(this)">🗑️</button></td>
                        </tr>
                    </tbody>
                    <tfoot>
                        <tr class="total-row">
                            <td colspan="3" style="text-align:right;">TOTAL:</td>
                            <td id="incomeTotal">$0.00</td>
                            <td></td>
                        </tr>
                    </tfoot>
                </table>
                <button class="btn btn-add" onclick="addIncomeRow()" style="margin-top:15px;">+ Add Income</button>
            </div>

            <!-- Expense Table -->
            <div class="table-container">
                <div class="table-header expense-header">
                    <span style="font-size: 1.8rem;">📤</span>
                    <h2>Expense Tracking</h2>
                </div>
                <table id="expenseTable">
                    <thead>
                        <tr>
                            <th>Date</th>
                            <th>Category</th>
                            <th>Description</th>
                            <th>Amount ($)</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody id="expenseBody">
                        <tr class="expense-row">
                            <td><input type="date" class="date-input"></td>
                            <td>
                                <select class="category-input">
                                    <option value="">Select</option>
                                    <option value="Subscriptions">Subscriptions</option>
                                    <option value="Advertising">Advertising</option>
                                    <option value="Tools/Software">Tools / Software</option>
                                    <option value="Transportation">Transportation</option>
                                    <option value="Food">Food & Dining</option>
                                    <option value="Bills">Bills & Utilities</option>
                                    <option value="Health">Health & Medical</option>
                                    <option value="Shopping">Shopping</option>
                                    <option value="Entertainment">Entertainment</option>
                                    <option value="Other">Other</option>
                                </select>
                            </td>
                            <td><input type="text" class="desc-input" placeholder="Description..."></td>
                            <td><input type="number" class="amount-input" placeholder="0.00" step="0.01" min="0"></td>
                            <td><button class="btn btn-remove" onclick="removeRow(this)">🗑️</button></td>
                        </tr>
                    </tbody>
                    <tfoot>
                        <tr class="total-row">
                            <td colspan="3" style="text-align:right;">TOTAL:</td>
                            <td id="expenseTotal">$0.00</td>
                            <td></td>
                        </tr>
                    </tfoot>
                </table>
                <button class="btn btn-add" onclick="addExpenseRow()" style="margin-top:15px;">+ Add Expense</button>
            </div>
        </div>

        <div class="action-buttons">
            <button class="btn btn-save" onclick="saveData()">💾 Save Data</button>
        </div>

        <div id="statusMessage" class="status-message"></div>
    </div>

    <script>
        // Set today's date on page load
        document.addEventListener('DOMContentLoaded', function() {
            const today = new Date().toISOString().split('T')[0];
            document.querySelectorAll('.date-input').forEach(input => {
                if (!input.value) input.value = today;
            });

            // Listen for input changes
            document.addEventListener('input', function(e) {
                if (e.target.classList.contains('amount-input')) {
                    calculateTotals();
                }
            });
        });

        function formatCurrency(amount) {
            return new Intl.NumberFormat('en-US', {
                style: 'currency',
                currency: 'USD'
            }).format(amount);
        }

        function calculateTotals() {
            let totalIncome = 0;
            let totalExpense = 0;

            // Calculate income
            document.querySelectorAll('#incomeBody .amount-input').forEach(input => {
                const value = parseFloat(input.value) || 0;
                totalIncome += value;
            });

            // Calculate expenses
            document.querySelectorAll('#expenseBody .amount-input').forEach(input => {
                const value = parseFloat(input.value) || 0;
                totalExpense += value;
            });

            const netBalance = totalIncome - totalExpense;
            const savingsRate = totalIncome > 0 ? ((totalIncome - totalExpense) / totalIncome * 100) : 0;

            // Update DOM
            document.getElementById('totalIncome').textContent = formatCurrency(totalIncome);
            document.getElementById('totalExpense').textContent = formatCurrency(totalExpense);
            document.getElementById('netBalance').textContent = formatCurrency(netBalance);
            document.getElementById('savingsRate').textContent = savingsRate.toFixed(1) + '%';
            document.getElementById('incomeTotal').textContent = formatCurrency(totalIncome);
            document.getElementById('expenseTotal').textContent = formatCurrency(totalExpense);

            // Progress bar
            const progressBar = document.getElementById('progressBar');
            const clampedRate = Math.max(0, Math.min(100, savingsRate));
            progressBar.style.width = clampedRate + '%';

            // Status message
            const statusDiv = document.getElementById('statusMessage');
            if (netBalance > 0) {
                statusDiv.className = 'status-message status-positive';
                statusDiv.textContent = '✅ Great job! You saved ' + formatCurrency(netBalance) + ' this month.';
                statusDiv.style.display = 'block';
            } else if (netBalance < 0) {
                statusDiv.className = 'status-message status-negative';
                statusDiv.textContent = '⚠️ Warning! You are over budget by ' + formatCurrency(Math.abs(netBalance)) + '.';
                statusDiv.style.display = 'block';
            } else {
                statusDiv.style.display = 'none';
            }
        }

        function addIncomeRow() {
            const tbody = document.getElementById('incomeBody');
            const newRow = document.createElement('tr');
            newRow.className = 'income-row';
            const today = new Date().toISOString().split('T')[0];

            newRow.innerHTML = `
                <td><input type="date" class="date-input" value="${today}"></td>
                <td>
                    <select class="source-input">
                        <option value="">Select</option>
                        <option value="Etsy Sales">Etsy Sales</option>
                        <option value="Gumroad Sales">Gumroad Sales</option>
                        <option value="Fiverr">Fiverr</option>
                        <option value="Shopify">Shopify</option>
                        <option value="Freelance">Freelance</option>
                        <option value="YouTube">YouTube</option>
                        <option value="Other Digital">Other Digital</option>
                        <option value="Salary">Salary</option>
                        <option value="Investments">Investments</option>
                    </select>
                </td>
                <td><input type="text" class="desc-input" placeholder="Description..."></td>
                <td><input type="number" class="amount-input" placeholder="0.00" step="0.01" min="0"></td>
                <td><button class="btn btn-remove" onclick="removeRow(this)">🗑️</button></td>
            `;

            tbody.appendChild(newRow);

            // Listen to new input
            newRow.querySelector('.amount-input').addEventListener('input', calculateTotals);
        }

        function addExpenseRow() {
            const tbody = document.getElementById('expenseBody');
            const newRow = document.createElement('tr');
            newRow.className = 'expense-row';
            const today = new Date().toISOString().split('T')[0];

            newRow.innerHTML = `
                <td><input type="date" class="date-input" value="${today}"></td>
                <td>
                    <select class="category-input">
                        <option value="">Select</option>
                        <option value="Subscriptions">Subscriptions</option>
                        <option value="Advertising">Advertising</option>
                        <option value="Tools/Software">Tools / Software</option>
                        <option value="Transportation">Transportation</option>
                        <option value="Food">Food & Dining</option>
                        <option value="Bills">Bills & Utilities</option>
                        <option value="Health">Health & Medical</option>
                        <option value="Shopping">Shopping</option>
                        <option value="Entertainment">Entertainment</option>
                        <option value="Other">Other</option>
                    </select>
                </td>
                <td><input type="text" class="desc-input" placeholder="Description..."></td>
                <td><input type="number" class="amount-input" placeholder="0.00" step="0.01" min="0"></td>
                <td><button class="btn btn-remove" onclick="removeRow(this)">🗑️</button></td>
            `;

            tbody.appendChild(newRow);

            // Listen to new input
            newRow.querySelector('.amount-input').addEventListener('input', calculateTotals);
        }

        function removeRow(btn) {
            const row = btn.closest('tr');
            const tbody = row.parentElement;

            if (tbody.children.length > 1) {
                row.remove();
                calculateTotals();
            } else {
                // Clear last row instead of removing
                row.querySelectorAll('input, select').forEach(input => {
                    if (input.type !== 'button') input.value = '';
                });
                calculateTotals();
            }
        }

        function saveData() {
            const data = {
                income: [],
                expense: [],
                totals: {
                    income: document.getElementById('totalIncome').textContent,
                    expense: document.getElementById('totalExpense').textContent,
                    balance: document.getElementById('netBalance').textContent,
                    savingsRate: document.getElementById('savingsRate').textContent
                },
                date: new Date().toLocaleDateString('en-US')
            };

            // Collect income data
            document.querySelectorAll('#incomeBody tr').forEach(row => {
                const date = row.querySelector('.date-input')?.value;
                const source = row.querySelector('.source-input')?.value;
                const desc = row.querySelector('.desc-input')?.value;
                const amount = row.querySelector('.amount-input')?.value;

                if (amount && parseFloat(amount) > 0) {
                    data.income.push({ date, source, desc, amount: parseFloat(amount) });
                }
            });

            // Collect expense data
            document.querySelectorAll('#expenseBody tr').forEach(row => {
                const date = row.querySelector('.date-input')?.value;
                const category = row.querySelector('.category-input')?.value;
                const desc = row.querySelector('.desc-input')?.value;
                const amount = row.querySelector('.amount-input')?.value;

                if (amount && parseFloat(amount) > 0) {
                    data.expense.push({ date, category, desc, amount: parseFloat(amount) });
                }
            });

            // Save to localStorage
            localStorage.setItem('incomeExpenseData', JSON.stringify(data));

            // Download as JSON file
            const dataStr = JSON.stringify(data, null, 2);
            const blob = new Blob([dataStr], { type: 'application/json' });
            const url = URL.createObjectURL(blob);
            const a = document.createElement('a');
            a.href = url;
            a.download = 'income-expense-' + new Date().toISOString().split('T')[0] + '.json';
            document.body.appendChild(a);
            a.click();
            document.body.removeChild(a);
            URL.revokeObjectURL(url);

            alert('✅ Data saved successfully! File downloaded.');
        }

        // Load saved data on page load
        window.addEventListener('load', function() {
            const savedData = localStorage.getItem('incomeExpenseData');
            if (savedData) {
                const data = JSON.parse(savedData);
                console.log('Loaded data:', data);
            }
        });
    </script>
</body>
</html>
